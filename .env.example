# Local development only. In production every value below is injected as an
# environment variable sourced from Secret Manager (the --set-secrets flags
# in the gcloud run deploy command) -- nothing here should ever be baked into
# the Docker image or committed with real values. See the writeup for why
# Secret Manager rather than just container env vars.

GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

FIRESTORE_COLLECTION=jobs

ASSEMBLYAI_API_KEY=changeme
ANTHROPIC_API_KEY=changeme
# Used for the YouTube transcript path (codepoetry/youtube-transcript-ai-scraper),
# which runs on Apify's own infrastructure instead of Cloud Run's -- Cloud Run's
# IP range is blocked by YouTube's bot detection, Apify's isn't (confirmed by test).
APIFY_API_TOKEN=changeme

# Shared secret clients (pipelines, iPhone Shortcut) send as X-API-Key.
API_KEY=changeme
# Separate secret only Cloud Tasks knows; locks down /internal/process.
INTERNAL_TASK_KEY=changeme

CLOUD_TASKS_QUEUE=transcription-queue
CLOUD_TASKS_LOCATION=us-central1
# Set this to the real Cloud Run URL after your first deploy, then redeploy.
SERVICE_URL=https://your-service-url.a.run.app

UPLOAD_BUCKET=your-project-uploads
